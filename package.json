{
    "name": "jira-ai-mcp-server",
    "version": "1.0.0",
    "description": "AI-powered Agile workflow automation via MCP — transforms meeting summaries into JIRA artifacts with human-in-the-loop approval",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "jira-ai-mcp": "dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsx src/index.ts",
        "dev:watch": "tsx watch src/index.ts",
        "typecheck": "tsc --noEmit",
        "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
        "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
        "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
        "clean": "rm -rf dist",
        "lint": "eslint 'src/**/*.ts'"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "latest",
        "@types/better-sqlite3": "^7.6.13",
        "axios": "latest",
        "better-sqlite3": "^12.6.2",
        "dotenv": "latest",
        "uuid": "latest",
        "winston": "latest",
        "zod": "latest"
    },
    "devDependencies": {
        "@types/jest": "latest",
        "@types/node": "latest",
        "@types/uuid": "latest",
        "@typescript-eslint/eslint-plugin": "latest",
        "@typescript-eslint/parser": "latest",
        "eslint": "latest",
        "jest": "latest",
        "ts-jest": "latest",
        "tsx": "latest",
        "typescript": "latest"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "jest": {
        "preset": "ts-jest/presets/default-esm",
        "extensionsToTreatAsEsm": [
            ".ts"
        ],
        "transform": {
            "^.+\\.tsx?$": [
                "ts-jest",
                {
                    "useESM": true
                }
            ]
        },
        "moduleNameMapper": {
            "^(\\.{1,2}/.*)\\.js$": "$1"
        },
        "testEnvironment": "node",
        "testMatch": [
            "**/__tests__/**/*.test.ts"
        ]
    }
}
