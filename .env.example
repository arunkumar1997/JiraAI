# ─── JIRA Connection ────────────────────────────────────────────────────────────
# URL of your self-hosted JIRA Data Center instance
JIRA_BASE_URL=http://localhost:8085

# Personal Access Token — generate at: http://localhost:8080/secure/ViewProfile.jspa
# Navigate to: Profile → Personal Access Tokens → Create Token
JIRA_PAT=your-personal-access-token-here

# Default JIRA project key (uppercase, matches your JIRA project)
JIRA_PROJECT_KEY=PROJ

# Agile board ID — find at: /rest/agile/1.0/board
JIRA_BOARD_ID=1

# ─── JIRA Custom Field IDs ────────────────────────────────────────────────────
# Custom field IDs vary per JIRA installation.
# Discover them by calling: GET /rest/api/2/field
# Look for fields with "custom": true and match by name.

# "Story Points" or "Story point estimate"
JIRA_FIELD_STORY_POINTS=customfield_10016

# "Epic Link" — used to associate Stories/Tasks to an Epic
JIRA_FIELD_EPIC_LINK=customfield_10014

# "Epic Name" — the short name displayed on the Epic card
JIRA_FIELD_EPIC_NAME=customfield_10011

# "Sprint" field
JIRA_FIELD_SPRINT=customfield_10020

# "Acceptance Criteria" (if your project has this field)
JIRA_FIELD_ACCEPTANCE_CRITERIA=customfield_10006

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/jira-ai-mcp.log

# ─── Draft Storage ────────────────────────────────────────────────────────────
# Path to persist draft state across restarts (relative to project root)
DRAFT_STORAGE_PATH=.drafts.json

# ─── Meeting Transcription (local Whisper) ────────────────────────────────────
# Path to the Python executable that has faster-whisper installed.
# Set this when faster-whisper is in a virtualenv rather than system python3.
# Example (venv):  WHISPER_PYTHON=/home/youruser/jiraAI/.venv/bin/python
# Leave unset to use system 'python3'
# WHISPER_PYTHON=python3
