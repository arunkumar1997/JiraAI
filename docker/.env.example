# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=jiradb
POSTGRES_USER=jira
# REQUIRED — change this before starting
POSTGRES_PASSWORD=changeme_strong_password_here

# ─── JIRA ────────────────────────────────────────────────────────────────────
# Hostname that JIRA will use in generated URLs
JIRA_HOSTNAME=localhost

# Port exposed by nginx (80 for http, 443 for https)
JIRA_PROXY_PORT=80

# http or https
JIRA_SCHEME=http
